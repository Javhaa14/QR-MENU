{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@qr-menu/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@qr-menu/shared-types/*": [
        "../../packages/shared-types/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ],
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
